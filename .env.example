APP_TITLE=Trade Ops Desk
APP_ENV=development
PRODUCTION_MODE=false
ROBO_STORAGE_DIR=storage

# Authentication
AUTH_REQUIRED=false
AUTH_SESSION_TIMEOUT_MINUTES=30
ADMIN_USERNAME=
ADMIN_PASSWORD=

# Persistence
DATABASE_URL=

# Market data
MARKET_DATA_PROVIDER=twelvedata
MARKET_DATA_FALLBACK_PROVIDER=yahoo
TWELVEDATA_API_KEY=
TWELVEDATA_API_BASE=https://api.twelvedata.com
TWELVEDATA_MIN_CACHE_TTL_SECONDS=900
MARKET_DATA_CACHE_TTL_SECONDS=300
MARKET_DATA_HISTORY_LIMIT=500

# Daily risk guard (paper trading)
DAILY_LOSS_LIMIT_BRL=100

# Broker scaffold
BROKER_PROVIDER=paper
BROKER_MODE=paper
BROKER_ACCOUNT_ID=
BROKER_BASE_URL=
BROKER_API_KEY=
BROKER_API_SECRET=
BROKER_HTTP_HEALTHCHECK=false

# Production monitoring and alerts
ALERT_EMAIL_ENABLED=false
ALERT_EMAIL_PROVIDER=smtp
ALERT_EMAIL_TO=oliveirasamuel03@gmail.com
ALERT_EMAIL_FROM=
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_TLS=true
SMTP_TIMEOUT_SECONDS=15
RESEND_API_KEY=
RESEND_API_BASE=https://api.resend.com/emails
ALERT_HEARTBEAT_MAX_DELAY_SECONDS=180
ALERT_MAX_CONSECUTIVE_ERRORS=3
ALERT_FEED_FALLBACK_MAX_MINUTES=15
ALERT_COOLDOWN_MINUTES=30
ALERT_SEND_RECOVERY_EMAIL=true
REPORT_EMAIL_ENABLED=false
REPORT_EMAIL_PROVIDER=smtp
REPORT_EMAIL_TO=
REPORT_EMAIL_FROM=
REPORT_EMAIL_SMTP_HOST=
REPORT_EMAIL_SMTP_PORT=587
REPORT_EMAIL_SMTP_USERNAME=
REPORT_EMAIL_SMTP_PASSWORD=
REPORT_EMAIL_USE_TLS=true
REPORT_EMAIL_TIMEOUT_SECONDS=15
REPORT_EMAIL_DAILY_ENABLED=true
REPORT_EMAIL_WEEKLY_ENABLED=true
REPORT_EMAIL_10DAY_ENABLED=true
REPORT_EMAIL_FINAL_ENABLED=true

# Retention and weekly validation
RETENTION_ENABLED=true
RETENTION_DAYS=60
RETENTION_RUN_INTERVAL_HOURS=24
RETENTION_ARCHIVE_TRADER_ORDERS=false
WEEKLY_REPORT_RUNTIME_WEEKS=8

# Streamlit
STREAMLIT_BROWSER_GATHER_USAGE_STATS=false
